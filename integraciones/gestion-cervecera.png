        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "¿Qué es Gestión Cervecera?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Es un software de gestión 100% en la nube diseñado exclusivamente para fábricas de cerveza artesanal. Permite controlar producción, costos, stock, trazabilidad y ventas desde cualquier dispositivo."
              }
            },
            {
              "@type": "Question",
              "name": "¿En qué países funciona Gestión Cervecera?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Gestión Cervecera es utilizado por cervecerías en Argentina, México, Chile, Colombia, Perú, Ecuador, Uruguay, Paraguay y más países de Latinoamérica."
              }
            },
            {
              "@type": "Question",
              "name": "¿Tiene prueba gratuita?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sí. Puedes probar todas las funcionalidades durante 15 días de forma gratuita, sin compromiso y sin tarjeta de crédito."
              }
            },
            {
              "@type": "Question",
              "name": "¿Qué funcionalidades incluye el software?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Incluye gestión de recetas y costeo por lote, control de producción, stock de insumos y productos terminados, trazabilidad completa, tracking de barriles con código QR, facturación electrónica, ventas, integración con e-commerce y más de 50 informes exportables."
              }
            },
            {
              "@type": "Question",
              "name": "¿Sirve para cervecerías pequeñas?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sí. Gestión Cervecera está diseñado para cervecerías artesanales de cualquier tamaño, desde microcervecerías que producen 500 litros al mes hasta fábricas con producción de más de 50.000 litros mensuales."
              }
            },
            {
              "@type": "Question",
              "name": "¿Cómo controla las mermas de producción?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "El sistema registra las mermas en cada etapa del proceso cervecero: cocción, fermentación, trasiego y envasado. Esto permite identificar dónde se pierde producto y tomar decisiones para reducir pérdidas y mejorar la rentabilidad."
              }
            }
          ]
        }
        </script>
