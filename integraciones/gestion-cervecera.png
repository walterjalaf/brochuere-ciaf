                                <!-- Carousel casos de exito -->
                                <style>
                                    #casosExitoCarousel { position: relative; text-align: center; padding: 0 10%; margin-bottom: 16px; }
                                    #casosExitoCarousel .caso-slides-wrap { position: relative; height: 300px; }
                                    #casosExitoCarousel .caso-slide { position: absolute; top: 0; left: 0; width: 100%; height: 300px; opacity: 0; transition: opacity 0.6s ease; pointer-events: none; display: flex; align-items: center; justify-content: center; flex-direction: column; }
                                    #casosExitoCarousel .caso-slide.caso-active { opacity: 1; pointer-events: auto; }
                                    #casosExitoCarousel img { width: 100%; height: 260px; object-fit: contain; border-radius: 4px; background: #fff; }
                                    #casosExitoCarousel .caso-caption { margin: 8px 0 0; font-size: 15px; font-weight: 600; color: #555; }
                                    #casosExitoCarousel .caso-arrow { position: absolute; top: 40%; transform: translateY(-50%); background: rgba(0,0,0,0.45); color: #fff; border: none; font-size: 20px; padding: 6px 12px; cursor: pointer; border-radius: 3px; z-index: 5; }
                                    #casosExitoCarousel .caso-arrow-prev { left: 0; }
                                    #casosExitoCarousel .caso-arrow-next { right: 0; }
                                    #casosExitoCarousel .caso-dots { margin-top: 10px; }
                                    #casosExitoCarousel .caso-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: #ccc; margin: 0 4px; cursor: pointer; transition: background 0.3s; }
                                    #casosExitoCarousel .caso-dot.caso-dot-active { background: #d99d25; }
                                </style>
