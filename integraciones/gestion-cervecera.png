                                <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
                                    (function () {
                                        var cur = 0, n = 4;
                                        var timer = setInterval(function () { casosMove(1); }, 3000);
                                        window.casosMove = function (d) { casosGo((cur + d + n) % n); };
                                        window.casosGo = function (i) {
                                            var sl = document.querySelectorAll('#casosExitoCarousel .caso-slide');
                                            var dt = document.querySelectorAll('#casosExitoCarousel .caso-dot');
                                            sl[cur].classList.remove('caso-active');
                                            dt[cur].classList.remove('caso-dot-active');
                                            cur = i;
                                            sl[cur].classList.add('caso-active');
                                            dt[cur].classList.add('caso-dot-active');
                                            clearInterval(timer);
                                            timer = setInterval(function () { casosMove(1); }, 3000);
                                        };
                                    })();
