        <!-- reCAPTCHA v3 — deferred until contact form is visible (JS-04) -->
        <script>
            (function() {
                var recaptchaLoaded = false;
                function loadRecaptcha() {
                    if (recaptchaLoaded) return;
                    recaptchaLoaded = true;
                    var s = document.createElement('script');
                    s.src = 'https://www.google.com/recaptcha/api.js?render=6LdAdsQUAAAAAOERb8ke7yurDY82WqwJRggbyjrw';
                    document.head.appendChild(s);
                }
                // Load when contact form scrolls into view, or on user interaction
                window.addEventListener('load', function() {
                    var contactEl = document.getElementById('contact');
                    if (contactEl && 'IntersectionObserver' in window) {
                        var observer = new IntersectionObserver(function(entries) {
                            if (entries[0].isIntersecting) {
                                loadRecaptcha();
                                observer.disconnect();
                            }
                        }, { rootMargin: '200px' });
                        observer.observe(contactEl);
                    } else {
                        // Fallback: load after 5 seconds
                        setTimeout(loadRecaptcha, 5000);
                    }
                });
            })();
        </script>
