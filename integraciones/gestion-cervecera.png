        <script>
            /* JS-01 fix: jQuery 3.x compatibility patches — must run BEFORE avia-footer-scripts
               Patch 1: outerHeight/outerWidth — jQuery 3.0 changed empty-set return from null to
               undefined. avia-footer-scripts does: h = $('#header_meta').outerHeight() which
               returns undefined (no #header_meta), then e -= h → e = NaN → all scroll comparisons
               fail (NaN < 44 = false) → header never transitions from transparent to white.
               Patch 2: offset() — jQuery 3.x offset() calls elem.getClientRects() which throws
               for hidden elements; wrap in try/catch for Waypoints compat. */
            if (window.jQuery) {
                var _outerHeight = jQuery.fn.outerHeight;
                jQuery.fn.outerHeight = function () {
                    var v = _outerHeight.apply(this, arguments);
                    return v === undefined ? 0 : v;
                };
                var _outerWidth = jQuery.fn.outerWidth;
                jQuery.fn.outerWidth = function () {
                    var v = _outerWidth.apply(this, arguments);
                    return v === undefined ? 0 : v;
                };
                var _offset = jQuery.fn.offset;
                jQuery.fn.offset = function () {
                    try { return _offset.apply(this, arguments); } catch (e) { return { top: 0, left: 0 }; }
                };
            }
        </script>
        <script type='text/javascript' src='/wp-content/uploads/dynamic_avia/avia-footer-scripts-58936e63f4da40de146d1f3eaa3e7f25---5f2ddbd17047d.js'></script>
        <script>
            /* JS-01 fix: transparency fallback — if avia's scroll handler didn't register
               (e.g. exception during setup), provide a native safety net.
               The primary fix is the outerHeight/outerWidth patch above. */
            window.addEventListener('load', function () {
                var header = document.getElementById('header');
                if (!header) return;
                var ticking = false;
                function updateTransparency() {
                    if (window.scrollY > 50) {
                        header.classList.remove('av_header_transparency');
                    } else {
                        header.classList.add('av_header_transparency');
                    }
                    ticking = false;
                }
                window.addEventListener('scroll', function () {
                    if (!ticking) {
                        window.requestAnimationFrame(updateTransparency);
                        ticking = true;
                    }
                }, { passive: true });
            }, { once: true });
        </script>
